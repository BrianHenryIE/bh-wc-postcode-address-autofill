<?xml version="1.0"?>
<ruleset name="WordPress Coding Standards">
    <description>WooCommerce extension PHP_CodeSniffer ruleset.</description>

    <arg name="extensions" value="php"/>
    <file>.</file>

    <!-- Exclude paths -->
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>/data/original/</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>/dist-archive/</exclude-pattern>
    <exclude-pattern>/scratch/</exclude-pattern>
    <exclude-pattern>/vendor/*</exclude-pattern>
    <exclude-pattern>/wordpress/</exclude-pattern>
    <exclude-pattern>/wp-content/</exclude-pattern>

    <!-- Configs -->
    <config name="minimum_supported_wp_version" value="4.7" />
    <config name="testVersion" value="7.4-" />

    <!-- Rules -->
    <rule ref="WordPress-Extra">
        <exclude name="Generic.Commenting.DocComment.SpacingAfter" />
        <exclude name="Generic.Files.LineEndings.InvalidEOLChar" />
        <exclude name="Generic.Functions.FunctionCallArgumentSpacing.SpaceBeforeComma" />
        <exclude name="PEAR.Functions.FunctionCallSignature" />
        <exclude name="Squiz.Commenting" />
        <exclude name="Squiz.PHP.DisallowSizeFunctionsInLoops.Found" />
        <exclude name="Squiz.WhiteSpace" />
        <exclude name="WordPress.Arrays" />
        <exclude name="WordPress.Files.FileName" />
        <exclude name="WordPress.NamingConventions" />
        <exclude name="WordPress.Security.ValidatedSanitizedInput.MissingUnslash" />
        <exclude name="WordPress.WP.I18n.NonSingularStringLiteralText" />
        <exclude name="WordPress.WhiteSpace" />
    </rule>

    <rule ref="WooCommerce-Core">
        <exclude name="Core.Commenting.CommentTags.AuthorTag" />
        <exclude name="WordPress.PHP.DontExtract" />
        <exclude name="Generic.Arrays.DisallowShortArraySyntax" />
        <exclude name="Generic.WhiteSpace.ScopeIndent.Incorrect" />
    </rule>

    <rule ref="PHPCompatibility">
        <exclude-pattern>tests/</exclude-pattern>
    </rule>

    <!-- ignore rules on Composer's own files -->
    <rule ref="Generic.Classes.OpeningBraceSameLine.BraceOnNewLine">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.Commenting.DocComment.LongNotCapital">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.Commenting.DocComment.MissingShort">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.Formatting.MultipleStatementAlignment.NotSameWarning">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.Functions.OpeningFunctionBraceKernighanRitchie.BraceOnNewLine">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.Strings.UnnecessaryStringConcat.Found">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Generic.WhiteSpace.DisallowSpaceIndent.SpacesUsed">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="PSR2.Files.EndFileNewline.NoneFound">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="PSR2.Methods.FunctionClosingBrace.SpacingBeforeClose">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing.SpacingAfterOpen">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Squiz.Functions.FunctionDeclarationArgumentSpacing.SpacingBeforeClose">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Squiz.PHP.DisallowMultipleAssignments.Found">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Squiz.Strings.ConcatenationSpacing.PaddingFound">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Universal.WhiteSpace.PrecisionAlignment.Found">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames.classFound">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="NormalizedArrays.Arrays.ArrayBraceSpacing.EmptyArraySpacing">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="NormalizedArrays.Arrays.ArrayBraceSpacing.SpaceAfterArrayOpenerSingleLine">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="NormalizedArrays.Arrays.ArrayBraceSpacing.SpaceAfterKeyword">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="NormalizedArrays.Arrays.ArrayBraceSpacing.SpaceBeforeArrayCloserSingleLine">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="WordPress.PHP.DevelopmentFunctions.error_log_trigger_error">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="WordPress.PHP.NoSilencedErrors.Discouraged">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="WordPress.PHP.YodaConditions.NotYoda">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>
    <rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
        <exclude-pattern>vendor-prefixed/composer</exclude-pattern>
    </rule>

</ruleset>